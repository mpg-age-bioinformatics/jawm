#!/bin/bash -e

############################################################
# Portable helpers (Linux + macOS)
############################################################

# Portable absolute path resolver (avoids readlink -f)
abspath() {
  # usage: abspath <path>
  local target="$1"
  if [ -z "$target" ]; then
    pwd -P
    return
  fi
  if [ -d "$target" ]; then
    (cd "$target" && pwd -P)
  else
    local dir
    dir="$(dirname "$target")"
    local base
    base="$(basename "$target")"
    (cd "$dir" 2>/dev/null && printf "%s/%s\n" "$(pwd -P)" "$base") || printf "%s\n" "$target"
  fi
}

# Cross-platform MD5 of a file -> prints "hash"
md5_file() {
  # Uses md5sum (Linux) or md5 (macOS)
  if command -v md5sum >/dev/null 2>&1; then
    md5sum "$1" | awk '{print $1}'
  elif command -v md5 >/dev/null 2>&1; then
    md5 -q "$1"
  else
    echo "ERROR: neither md5sum nor md5 found" >&2
    return 1
  fi
}

array_is() {
  # $1 = expected value, rest = array elements
  local expected="$1"; shift
  local arr=("$@")

  # Must have exactly one element AND match
  [[ ${#arr[@]} -eq 1 && "${arr[0]}" == "$expected" ]]
}

############################################################
# Parse arguments
############################################################

# Default values
RUNNER="local"
DISPATCHED=false
OVERRIDE=false
IGNORE=false

# Declare arrays explicitly (works on macOS bash 3.2)
declare -a YAML_FILES MODULE_VERSIONS PYTHON_VERSIONS JAWM_VERSIONS SKIP_PYTHON_VERSIONS

# Single tests file (portable realpaths)
TESTS_FILE="$(abspath ./test/tests.txt)"
DOWNLOADS_FILE="$(abspath ./test/data.txt)"
LOGS_FOLDER="$(abspath ./test/logs)"
JAWM_REPO="github.com/mpg-age-bioinformatics/jawm.git"

# Parse arguments
while [[ $# -gt 0 ]]; do
  case $1 in
    -r|--runner) RUNNER="$2"; shift 2 ;;
    -d|--dispatch) DISPATCHED=true; shift ;;
    -y|--yaml)
      shift
      while [[ $# -gt 0 && $1 != -* ]]; do
        YAML_FILES+=("$(abspath "$1")")
        shift
      done
      ;;
    -o|--override) OVERRIDE=true; shift ;;
    --no-override) OVERRIDE=false; shift ;;
    -i|--ignore) IGNORE=true; shift ;;
    -m|--module_versions)
      shift
      while [[ $# -gt 0 && $1 != -* ]]; do MODULE_VERSIONS+=("$1"); shift; done
      ;;
    -p|--python_versions)
      shift
      while [[ $# -gt 0 && $1 != -* ]]; do PYTHON_VERSIONS+=("$1"); shift; done
      ;;
    --skip_python_versions)
      shift
      while [[ $# -gt 0 && $1 != -* ]]; do SKIP_PYTHON_VERSIONS+=("$1"); shift; done
      ;;
    -j|--jawm_versions)
      shift
      while [[ $# -gt 0 && $1 != -* ]]; do JAWM_VERSIONS+=("$1"); shift; done
      ;;
    --jawm_repo) JAWM_REPO="$2"; shift 2 ;;
    -t|--tests_file) TESTS_FILE="$2"; shift 2 ;;
    --downloads_file) DOWNLOADS_FILE="$(abspath "$2")"; shift 2 ;;
    -h|--help)
      cat <<'EOF'
Usage:
  $(basename "$0") [options]
...
EOF
      exit 0
      ;;
    *) echo "Unknown option: $1" >&2; exit 1 ;;
  esac
done

# Normalize paths after possible overrides
TESTS_FILE="$(abspath "$TESTS_FILE")"
DOWNLOADS_FILE="$(abspath "$DOWNLOADS_FILE")"
LOGS_FOLDER="$(abspath "$LOGS_FOLDER")"

# Validate runner
if [[ -z "$RUNNER" || ! "$RUNNER" =~ ^(local|github|download)$ ]]; then
  echo "Error: --runner must be 'local', 'github', or 'download'." >&2
  exit 1
fi

# If local folder given for JAWM_REPO, force JAWM_VERSIONS=local
if [[ -d "$JAWM_REPO" ]]; then
  echo "WARNING: Local jawm source detected at '$JAWM_REPO'. Forcing jawm version to 'local'."
  JAWM_VERSIONS=("local")
fi

# Defaults if not provided
if [ ${#JAWM_VERSIONS[@]} -eq 0 ]; then JAWM_VERSIONS=("local"); fi
if [ ${#PYTHON_VERSIONS[@]} -eq 0 ]; then PYTHON_VERSIONS=("system"); fi

# Example usage
echo "Runner: $RUNNER"
echo "Dispatched: $DISPATCHED"
echo "Extra yaml files: ${YAML_FILES[*]:-None}"
echo "Override existing hashes: $OVERRIDE"
echo "Ignore failed tests: $IGNORE"
echo "Test file: ${TESTS_FILE:-None}"
echo "Downloads file: ${DOWNLOADS_FILE:-None}"
echo "jawm repo/folder: ${JAWM_REPO}"
echo "Specified module Versions: ${MODULE_VERSIONS[*]:-None}"
echo "Specified Python Versions: ${PYTHON_VERSIONS[*]:-None}"
echo "Skip Python Versions: ${SKIP_PYTHON_VERSIONS[*]:-None}"
echo "Specified jawm Versions: ${JAWM_VERSIONS[*]:-None}"

############################################################
# set paths
############################################################
FULLPATH="$(abspath .)"
DIRPATH="$FULLPATH"
TESTPATH="${FULLPATH}/test"

############################################################
# download data
############################################################
if [ -f "$DOWNLOADS_FILE" ]; then
  mkdir -p "${TESTPATH}/test-input"
  cd "${TESTPATH}/test-input" || exit 1

  # Read 3 columns: <md5> <filename> <url>
  while IFS= read -r line || [ -n "$line" ]; do
    # Skip empty or commented lines
    [[ -z "$line" || "$line" == \#* ]] && continue
    set -- $line
    hash_expected="$1"
    filename="$2"
    url="$3"
    echo "$filename $url"
    if [ ! -f "$filename" ]; then
      # wget -O "$filename" "$url"
      curl -L -o "$filename" "$url"
      # If it ends with .tar.gz or .tgz, extract it

      case "$filename" in
        *.tar.gz|*.tgz)
          echo "Extracting tar archive $filename..."
          tar -xzf "$filename"
          ;;
        *.fastq.gz)
          echo "Leaving FASTQ gzipped: $filename"
          ;;
        *.gz)
          echo "Decompressing $filename..."
          gunzip "$filename"
          ;;
      esac
fi
    fi
    # Verify MD5
    hash_actual="$(md5_file "$filename")" || { echo "Checksum tool not found."; exit 1; }
    if [ "$hash_actual" != "$hash_expected" ]; then
      echo "ERROR: MD5 mismatch for $filename"
      echo " expected: $hash_expected"
      echo "   actual: $hash_actual"
      exit 1
    fi
  done < "$DOWNLOADS_FILE"
fi

if [[ "$RUNNER" == "download" ]]; then
  exit 0
fi

############################################################
# preparing pyenv
############################################################

if ! array_is "system" "${PYTHON_VERSIONS[@]}" || \
   ! array_is "local"  "${JAWM_VERSIONS[@]}" ; then
  
  export PATH="$HOME/.pyenv/bin:$PATH"
  if command -v pyenv >/dev/null 2>&1; then
    echo "pyenv is already installed"
  else
    echo "pyenv not found, installing..."
    curl https://pyenv.run | bash
    echo "pyenv installed successfully."
    export PATH="$HOME/.pyenv/bin:$PATH"
  fi

  # Initialize pyenv for this process (no need to source shell rc files)
  eval "$(pyenv init --path)"
  eval "$(pyenv init -)"
  if command -v pyenv-virtualenv-init >/dev/null 2>&1; then
    eval "$(pyenv virtualenv-init -)"
  fi

fi

############################################################
# installing different python versions
############################################################

# Filter out skipped Python versions portably
if [ ${#SKIP_PYTHON_VERSIONS[@]} -gt 0 ]; then
  filtered=()
  for ver in "${PYTHON_VERSIONS[@]}"; do
    skip_it=false
    for s in "${SKIP_PYTHON_VERSIONS[@]}"; do
      if [ "$ver" = "$s" ]; then skip_it=true; break; fi
    done
    $skip_it || filtered+=("$ver")
  done
  PYTHON_VERSIONS=("${filtered[@]}")
fi

# Install requested pyenv Pythons (except 'system')
for PYTHON_VERSION in "${PYTHON_VERSIONS[@]}"; do
  if [[ "$PYTHON_VERSION" == "system" ]]; then continue; fi
  if pyenv versions --bare | grep -qx "$PYTHON_VERSION"; then
    echo "Python $PYTHON_VERSION is already installed"
  else
    echo "Installing Python $PYTHON_VERSION..."
    if ! pyenv install "$PYTHON_VERSION"; then
      echo "WARN: Python $PYTHON_VERSION could not be installed; skipping it."
      # remove from list
      tmp=()
      for pv in "${PYTHON_VERSIONS[@]}"; do
        [ "$pv" = "$PYTHON_VERSION" ] || tmp+=("$pv")
      done
      PYTHON_VERSIONS=("${tmp[@]}")
    fi
  fi
done

if ! array_is "system" "${PYTHON_VERSIONS[@]}" || \
   ! array_is "local"  "${JAWM_VERSIONS[@]}" ; then

  echo "Your python versions and environments can be found under: ~/.pyenv/versions/"

fi

############################################################
# get latest jawm tag and latest commit (only if needed)
############################################################
# If JAWM_VERSIONS was explicitly set (non-empty array), keep it as-is.
# Otherwise we defaulted earlier to ("local"), which is already portable.

############################################################
# install different jawm versions
############################################################

if ! array_is "system" "${PYTHON_VERSIONS[@]}" || \
   ! array_is "local"  "${JAWM_VERSIONS[@]}" ; then

  for PYTHON_VERSION in "${PYTHON_VERSIONS[@]}"; do
    for JAWM_VERSION in "${JAWM_VERSIONS[@]}"; do

      if [[ "$PYTHON_VERSION" == "system" ]]; then
        echo "Using system Python for jawm@${JAWM_VERSION}"
        PYTHON_BIN="$(command -v python3 || command -v python || true)"
        if [[ -z "$PYTHON_BIN" ]]; then
          echo "❌ No system Python found! Please install python3."
          exit 1
        fi
        # Ensure user-site bin on PATH for pip --user
        USER_BIN="$($PYTHON_BIN -c 'import site,sys; sys.stdout.write(site.USER_BASE + "/bin\n")' 2>/dev/null || true)"
        if [ -n "$USER_BIN" ]; then export PATH="$USER_BIN:$PATH"; fi

        if [[ "$JAWM_VERSION" == "local" ]]; then
          if [[ -d "$JAWM_REPO" ]]; then
            echo "(Re)Installing local jawm from $JAWM_REPO (system Python)"
            pip install --user --force-reinstall "$JAWM_REPO"
            echo "✅ System jawm install complete."
          else
            echo "INFO: No jawm path '$JAWM_REPO' was given." >&2
            # exit 1
          fi
        else
          # Install from Git
          echo "Installing 'jawm@${JAWM_VERSION}' (system Python)"
          pip install --user "git+ssh://git@${JAWM_REPO}@${JAWM_VERSION}"
          echo "✅ System jawm install complete."
        fi
        continue
      fi

      # pyenv-based Pythons
      ENV_NAME="py${PYTHON_VERSION}-jawm.${JAWM_VERSION}"
      if pyenv virtualenvs --bare | grep -qx "$ENV_NAME"; then
        echo "Virtual environment '$ENV_NAME' already exists."
      else
        echo "Creating virtual environment '$ENV_NAME'"
        pyenv virtualenv "$PYTHON_VERSION" "$ENV_NAME"
      fi

      # Activate
      # shellcheck disable=SC1090
      pyenv activate "$ENV_NAME"
      export PATH="$HOME/.pyenv/versions/${ENV_NAME}/bin/:$PATH"

      if [[ "$JAWM_VERSION" == "local" ]]; then
        if [[ -d "$JAWM_REPO" ]]; then
          echo "Installing jawm from $JAWM_REPO in $ENV_NAME."
          pip install --force-reinstall "$JAWM_REPO"
        else
          echo "ERROR: Local jawm path '$JAWM_REPO' not found." >&2
          pyenv deactivate
          exit 1
        fi
      else
        if pyenv exec pip show jawm >/dev/null 2>&1; then
          echo "'jawm' already installed in $ENV_NAME; reinstalling pinned rev."
        fi
        echo "Installing 'jawm@${JAWM_VERSION}' in $ENV_NAME."
        pip install "git+ssh://git@${JAWM_REPO}@${JAWM_VERSION}"
      fi

      echo "Installed jawm binary: $(command -v jawm || true)"
      pyenv deactivate
    done
  done
fi

############################################################
# set module tag(s)
############################################################
if [ ${#MODULE_VERSIONS[@]} -eq 0 ]; then
  if [[ "$RUNNER" == "local" ]]; then
    cd "$DIRPATH"
    CODE_TAG="current"
    if [[ "$DISPATCHED" == true ]]; then
      VERSION_TAG="$(git describe --tags --abbrev=0 2>/dev/null || echo "")"
    fi
    MODULE_VERSIONS=($CODE_TAG)
    [ -n "$VERSION_TAG" ] && MODULE_VERSIONS+=("$VERSION_TAG")
  elif [[ "$RUNNER" == "github" ]]; then
    VERSION_TAG="${GITHUB_REF_NAME}"
    echo "VERSION_TAG=${GITHUB_REF_NAME}" >> "$GITHUB_ENV"
    CODE_TAG="$(git rev-parse --short HEAD)"
    echo "CODE_TAG=${CODE_TAG}" >> "$GITHUB_ENV"
    if [[ "$DISPATCHED" == true ]]; then
      MODULE_VERSIONS=("$CODE_TAG" "$VERSION_TAG")
    elif [[ "${GITHUB_REF_TYPE}" == "tag" ]]; then
      MODULE_VERSIONS=("$VERSION_TAG")
    else
      MODULE_VERSIONS=("$CODE_TAG")
    fi
  fi
fi

############################################################
# run tests
############################################################
for PYTHON_VERSION in "${PYTHON_VERSIONS[@]}"; do
  for JAWM_VERSION in "${JAWM_VERSIONS[@]}"; do

    if [[ "$PYTHON_VERSION" == "system" ]]; then
      echo "Skipping pyenv activation for system Python (${JAWM_VERSION})"
      PY_BIN="$(command -v python3 || command -v python)"
      USER_BIN="$($PY_BIN -c 'import site,sys; sys.stdout.write(site.USER_BASE + "/bin\n")' 2>/dev/null || true)"
      if [ -n "$USER_BIN" ]; then export PATH="$USER_BIN:$PATH"; fi
    else
      ENV_NAME="py${PYTHON_VERSION}-jawm.${JAWM_VERSION}"
      pyenv activate "$ENV_NAME"
      export PATH="$HOME/.pyenv/versions/${ENV_NAME}/bin/:$PATH"
    fi

    for MODULE_VERSION in "${MODULE_VERSIONS[@]}"; do
      cd "$DIRPATH"
      if [ "$MODULE_VERSION" != "current" ]; then git checkout "$MODULE_VERSION"; fi

      rm -f "${TESTS_FILE}.tmp"
      head -n 1 "$TESTS_FILE" > "${TESTS_FILE}.tmp"

      while IFS=';' read -r MOD WORKFLOW PARAM NAME STORED_HASH || [ -n "$MOD" ]; do
        [[ -z "$MOD" || "$MOD" == \#* ]] && continue

        NAME="${NAME%\"}"; NAME="${NAME#\"}"

        echo "MODULE: $MOD"
        echo "WORKFLOW: $WORKFLOW"
        echo "PARAMETERS: $PARAM"
        echo "NAME: $NAME"
        echo "STORED HASH: ${STORED_HASH:-None}"
        echo "PYTHON VERSION: ${PYTHON_VERSION}"
        echo "JAWM VERSION: ${JAWM_VERSION}"
        echo "MODULE VERSION: ${MODULE_VERSION}"
        echo "PWD: $(pwd)"
        echo "JAWM COMMAND: jawm ${MOD} ${WORKFLOW} -l ${LOGS_FOLDER} -p $PARAM ${YAML_FILES[*]}"
        echo "------"

        FAILED=false
        if [[ $IGNORE == false ]]; then
          jawm "$MOD" "$WORKFLOW" -l "$LOGS_FOLDER" -p $PARAM "${YAML_FILES[@]}" \
            || { echo 'Error: jawm failed. Test failed.'; rm -f "${TESTS_FILE}.tmp"; exit 1; }
        else
          jawm "$MOD" "$WORKFLOW" -l "$LOGS_FOLDER" -p $PARAM "${YAML_FILES[@]}" \
            || { echo 'Warning: jawm failed. Test failed.'; FAILED=true; }
        fi

        if [[ $FAILED == false ]]; then
          NEW_HASH="$(cat "${LOGS_FOLDER}/jawm_hashes/$(basename "${MOD%.py}").hash")"

          echo "Stored HASH:    ${STORED_HASH}"
          echo "Generated HASH: ${NEW_HASH}"

          if [[ -z "$STORED_HASH" ]]; then
            echo "$MOD;$WORKFLOW;$PARAM;\"$NAME\";${NEW_HASH}" >> "${TESTS_FILE}.tmp"
          else
            if [[ "$NEW_HASH" != "$STORED_HASH" ]]; then
              echo "Warning: Hashes do not match!"
              if [[ $OVERRIDE == true ]]; then
                echo "Overwriting existing HASH."
                echo "$MOD;$WORKFLOW;$PARAM;\"$NAME\";${NEW_HASH}" >> "${TESTS_FILE}.tmp"
              else
                if [[ $IGNORE == false ]]; then
                  echo "Error: Hashes do not match! Test failed."
                  rm -f "${TESTS_FILE}.tmp"
                  exit 1
                else
                  echo "Keeping stored HASH."
                  echo "$MOD;$WORKFLOW;$PARAM;\"$NAME\";${STORED_HASH}" >> "${TESTS_FILE}.tmp"
                fi
              fi
            else
              echo "$MOD;$WORKFLOW;$PARAM;\"$NAME\";${STORED_HASH}" >> "${TESTS_FILE}.tmp"
            fi
          fi
        fi
      done < "$TESTS_FILE"

      mv "${TESTS_FILE}.tmp" "$TESTS_FILE"
    done

    if [[ "$PYTHON_VERSION" != "system" ]]; then
      pyenv deactivate
    fi
  done
done