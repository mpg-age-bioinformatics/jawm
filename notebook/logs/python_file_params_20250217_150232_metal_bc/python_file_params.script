#!/usr/bin/env python3
import time
print("Hello from FileApp")
print("4 + 3 =", 4 + 3)
print("start sleeping!")
time.sleep(15)
print("Print some fruits name:")
for fruit in ["Apple", "Banana", "Orange"]:
    print(f"Fruit: {fruit}")
print("Goodbye from File!")

